# ============================================================
# Required
# ============================================================

# Telegram bot token from @BotFather
TG_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Telegram channel (username with @ or numeric ID)
CHANNEL_ID=@your_channel

# AI Provider to use (gemini or openai)
AI_PROVIDER=gemini

# Google Gemini API key (required if AI_PROVIDER=gemini)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI API key (required if AI_PROVIDER=openai)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# Optional (defaults shown)
# ============================================================

# Model settings
GEMINI_MODEL=gemini-1.5-flash
OPENAI_MODEL=gpt-4o-mini

# Max articles processed per run
MAX_ARTICLES_PER_RUN=5

# Path to SQLite database (do not commit this file)
DATABASE_PATH=processed.db

# Extra RSS feeds: comma-separated Name|URL pairs (icon is optional: Name|URL|emoji)
# CUSTOM_RSS_FEEDS=Habr|https://habr.com/ru/rss/,VC.ru|https://vc.ru/rss

# ============================================================
# Required Telegram settings
# ============================================================

# Telegram bot token from @BotFather
TG_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Telegram channel username or numeric chat ID
CHANNEL_ID=@your_channel

# Main provider values: gemini, openai_compatible
# Compatibility aliases: openai, kimi
AI_PROVIDER=gemini

# ============================================================
# Backend credentials
# ============================================================

# Required if AI_PROVIDER=gemini
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Required if AI_PROVIDER=openai_compatible
# Works for OpenAI and OpenAI-compatible backends
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# Optional backend settings
# ============================================================

GEMINI_MODEL=gemini-1.5-flash
OPENAI_MODEL=gpt-4o-mini

# Set this for self-hosted or third-party OpenAI-compatible APIs
# Example: https://api.openai.com/v1
OPENAI_BASE_URL=

# Compatibility-only inputs for existing Kimi setups
# New setups should prefer AI_PROVIDER=openai_compatible with OPENAI_BASE_URL
# KIMI_API_KEY=
# KIMI_MODEL=moonshotai/kimi-k2.5

# ============================================================
# Optional runtime settings
# ============================================================

# Number of new articles to process per run
MAX_ARTICLES_PER_RUN=5

# Path to the RSS feeds YAML configuration file
# FEEDS_CONFIG_PATH=feeds.yaml

# Path to SQLite state (do not commit this file)
DATABASE_PATH=processed.db

# Backward compatibility: RSS feeds as an environment string
# Format: "Name1|URL1|Icon1,Name2|URL2|Icon2"
# CUSTOM_RSS_FEEDS="Habr|https://habr.com/ru/rss/|HB"

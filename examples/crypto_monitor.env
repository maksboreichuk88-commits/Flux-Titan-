# ==============================================================================
# 📱 Telegram Settings
# ==============================================================================
TG_TOKEN=your_telegram_bot_token_here
CHANNEL_ID=@your_crypto_channel_here

# ==============================================================================
# 🧠 AI Summarization Settings
# ==============================================================================
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# ==============================================================================
# 📰 RSS Feeds Configuration (Crypto Edition)
# ==============================================================================
MAX_ARTICLES_PER_RUN=5

# A comma-separated list of RSS feeds.
# Format: "Name|URL|Icon"
#
# Included crypto feeds:
# - CoinTelegraph
# - CoinDesk
# - Decrypt
CUSTOM_RSS_FEEDS="CoinTelegraph|https://cointelegraph.com/rss|🪙,CoinDesk|https://www.coindesk.com/arc/outboundfeeds/rss/|📈,Decrypt|https://decrypt.co/feed|🔐"

# =============================================================
# Telegram settings
# =============================================================
TG_TOKEN=your_telegram_bot_token_here
CHANNEL_ID=@your_crypto_channel_here

# =============================================================
# AI backend settings
# =============================================================
AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# =============================================================
# Source configuration (Crypto newsroom)
# =============================================================
MAX_ARTICLES_PER_RUN=5

# Format: "Name|URL|Icon"
CUSTOM_RSS_FEEDS="CoinTelegraph|https://cointelegraph.com/rss|CT,CoinDesk|https://www.coindesk.com/arc/outboundfeeds/rss/|CD,Decrypt|https://decrypt.co/feed|DC"

# =============================================================
# Telegram settings
# =============================================================
TG_TOKEN=your_telegram_bot_token_here
CHANNEL_ID=@your_channel_handle_here

# =============================================================
# AI backend settings
# =============================================================
AI_PROVIDER=openai_compatible
OPENAI_API_KEY=your_openai_compatible_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Optional for self-hosted or third-party OpenAI-compatible APIs
# OPENAI_BASE_URL=https://example.com/v1

# =============================================================
# Source configuration (Tech newsroom)
# =============================================================
MAX_ARTICLES_PER_RUN=3

# Format: "Name|URL|Icon"
CUSTOM_RSS_FEEDS="TechCrunch|https://techcrunch.com/feed/|TC,The Verge|https://www.theverge.com/rss/index.xml|TV,Wired|https://www.wired.com/feed/rss|WI,HackerNews|https://news.ycombinator.com/rss|HN"

# ==============================================================================
# 📱 Telegram Settings
# ==============================================================================
# Your Telegram Bot Token (Get this from @BotFather on Telegram)
TG_TOKEN=your_telegram_bot_token_here

# The target channel or chat ID (e.g., @my_tech_news or -10012345678)
# Ensure the bot is added as an admin with posting privileges!
CHANNEL_ID=@your_channel_handle_here

# ==============================================================================
# 🧠 AI Summarization Settings
# ==============================================================================
# Your Google Gemini API Key (Get this from https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# The AI Model to use. 'gemini-1.5-flash' is recommended for speed and cost.
GEMINI_MODEL=gemini-1.5-flash

# ==============================================================================
# 📰 RSS Feeds Configuration (Tech News Edition)
# ==============================================================================
# How many articles should the bot process and post in a single run? 
# Keep this low (1-5) if running frequently (e.g., every hour via cron).
MAX_ARTICLES_PER_RUN=3

# A comma-separated list of RSS feeds.
# Format: "Name|URL|Icon"
#
# Included tech feeds:
# - TechCrunch
# - The Verge
# - Wired
# - Hacker News (Frontpage)
CUSTOM_RSS_FEEDS="TechCrunch|https://techcrunch.com/feed/|🔶,The Verge|https://www.theverge.com/rss/index.xml|🔷,Wired|https://www.wired.com/feed/rss|⚡,HackerNews|https://news.ycombinator.com/rss|👾"
